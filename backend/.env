# OpenAI-compatible Bedrock endpoint (RECOMMENDED)
# These variables enable using LangChain's ChatOpenAI with Bedrock
OPENAI_API_KEY=""
OPENAI_BASE_URL=https://bedrock-mantle.ap-northeast-1.api.aws/v1

# LLM Model ID (Models available in ap-northeast-1 Tokyo region)
# Mistral models (recommended):
# - mistral.ministral-3-14b-instruct
# - mistral.magistral-small-2509
# Other models:
# - meta.llama3-70b-instruct-v1:0
# - meta.llama3-8b-instruct-v1:0
# - amazon.titan-text-express-v1
LLM_MODEL_ID=mistral.ministral-3-14b-instruct

# Local Docker service defaults for backend integration when the backend runs on the host
DATABASE_URL=postgresql://callitaday:callitaday@localhost:5432/callitaday
MILVUS_HOST=localhost
MILVUS_PORT=19530
ELASTICSEARCH_URL=http://localhost:9200
LANGFUSE_ENABLED=false
# For local LangFuse Docker, use the published UI/API port on localhost:
# LANGFUSE_HOST=http://localhost:3002
LANGFUSE_HOST=https://api.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGCHAIN_VERBOSE=false
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_INSECURE=true
