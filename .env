# Model Configuration (OpenAI-compatible endpoint for AWS Bedrock via bedrock-mantle)
MODEL_API_KEY=""
MODEL_BASE_URL=https://bedrock-mantle.ap-northeast-1.api.aws/v1
DEFAULT_LLM_MODEL=mistral.ministral-3-14b-instruct

# Embedding / Reranker
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L6-v2

# LangSmith (optional)
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=call-it-a-day
LANGSMITH_API_KEY=

# Local Docker service defaults for the backend when backend runs locally on the host
DATABASE_URL=postgresql://callitaday:callitaday@localhost:5432/callitaday
MILVUS_HOST=localhost
MILVUS_PORT=19530
ELASTICSEARCH_URL=http://localhost:9200
LANGFUSE_ENABLED=false
# For local LangFuse Docker, use the published UI/API port on localhost:
# LANGFUSE_HOST=http://localhost:3002
LANGFUSE_HOST=https://api.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGCHAIN_VERBOSE=false
